# --- AI summarization (optional; falls back to extractive summary) ---
# Groq is free and preferred when set. OpenAI is used only if no Groq key.
GROQ_API_KEY=
# Cheap model for the single batched daily brief.
GROQ_MODEL=llama-3.1-8b-instant
# Stronger model used only for on-demand `explain`/`compare`.
GROQ_DEEP_MODEL=llama-3.3-70b-versatile
# Hard local caps so we never exceed the Groq free tier.
GROQ_MAX_DAILY_REQUESTS=20
GROQ_MAX_TOKENS_PER_DIGEST=6000
OPENAI_API_KEY=

# --- News sourcing (optional; falls back to GDELT) ---
NEWS_API_KEY=

# --- Delivery channel: ntfy | twilio | slack | console ---
DELIVERY_CHANNEL=ntfy

# --- ntfy push notifications (free, no account) ---
# Pick a unique, hard-to-guess topic and subscribe to it in the ntfy phone app.
NTFY_TOPIC=pulsebrief-changeme-1234
NTFY_SERVER=https://ntfy.sh
NTFY_TOKEN=

# Full brief opens in browser when you tap the ntfy notification.
# GitHub Actions sets this automatically after Pages deploy.
# Local dev: use your Pages URL or http://localhost:8000/brief with ngrok.
BRIEF_PUBLIC_URL=https://nithin0120.github.io/pulsebrief/brief.html

# --- Twilio (only used if DELIVERY_CHANNEL=twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# --- Slack (only used if DELIVERY_CHANNEL=slack) ---
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# --- Scheduling & limits ---
# Digest runs every N hours. RUN_ON_STARTUP fires one shortly after the server starts.
DIGEST_INTERVAL_HOURS=6
RUN_ON_STARTUP=true
DIGEST_TIME=08:00
TIMEZONE=America/Los_Angeles
MAX_ARTICLES_PER_TOPIC=3
MAX_TOTAL_ARTICLES=40
# Max stories any single outlet can contribute to a digest (source diversity).
MAX_PER_SOURCE=2

# --- Quality filtering ---
# Candidates pulled per topic before AI importance/category triage.
CANDIDATES_PER_TOPIC=6
# Drop anything the AI scores below this importance (1-10). Higher = stricter.
MIN_IMPORTANCE=7
